{{!-- Food item sheet — edible/drinkable provisions for the food & drink
      homebrew. Two-layer:
        DISPLAY  → Witcher 3 in-game tooltip aesthetic (player reads)
        CONFIG   → editable form (cog toggle, owners only)

      Fields:
        cost / weight / availability / description → universal item fields,
            always rendered.
        taste                  → posted to chat on consume; never on the
                                 display layer per spec — config-only input.
        charges {current, max} → portion ticker; gated on foodAndDrinkOn.
        satietyRestore         → satiety regained per portion; gated.
        drunk.*                → alcoholic metadata (DC, level jump, flavor
                                 verb, witcher-resist bypass, icon); gated. --}}

<div class="wdm-item-sheet wdm-item-v2" data-mode="{{mode}}">

  {{#if canEdit}}
    <button type="button" class="wdm-item-cog" data-action="toggleItemMode"
            title="{{#if (eq mode 'config')}}Back to display view{{else}}Configure item{{/if}}">
      <i class="fa-solid {{#if (eq mode 'config')}}fa-eye{{else}}fa-gear{{/if}}"></i>
    </button>
  {{/if}}

  {{!-- ════════════════════════════════════════════════════════════
       DISPLAY VIEW — Witcher 3 tooltip layout
       ═══════════════════════════════════════════════════════════ --}}
  <div class="wdm-display-view" data-rarity="{{source.availability}}">
    <div class="wdm-w3">

      <header class="wdm-w3-head">
        <img class="wdm-w3-portrait" src="{{item.img}}" alt="" />
        <div class="wdm-w3-titles">
          <h1 class="wdm-w3-title">{{item.name}}</h1>
          <div class="wdm-w3-subtitle">
            {{kindLabel}}{{#if (and foodAndDrinkOn isDrink source.drunk.isAlcohol)}} · Alcoholic{{/if}}
          </div>
        </div>
      </header>

      {{!-- Charges + satiety + alcohol DC stripe (homebrew-only). --}}
      {{#if foodAndDrinkOn}}
        <ul class="wdm-w3-stats">
          {{#if source.charges.max}}
            <li class="wdm-w3-stat">
              <span class="val">{{source.charges.current}}/{{source.charges.max}}</span>
              <span class="lbl">Portions</span>
            </li>
          {{/if}}
          {{#unless (eq source.satietyRestore 0)}}
            <li class="wdm-w3-stat">
              <span class="val">+{{source.satietyRestore}}</span>
              <span class="lbl">Satiety / portion</span>
            </li>
          {{/unless}}
          {{#if source.drunk.isAlcohol}}
            <li class="wdm-w3-stat">
              <span class="val">DC {{source.drunk.dc}}</span>
              <span class="lbl">Endurance vs drunk</span>
            </li>
          {{/if}}
        </ul>

        {{!-- Freshness badge. Hidden when the GM didn't author a shelf life
              or the item hasn't been acquired yet (freshness.tracked === false). --}}
        {{#if freshness.tracked}}
          <div class="wdm-food-freshness is-{{freshness.state}}">
            <i class="fa-solid {{freshness.icon}}"></i>
            <span class="wdm-food-freshness-label">{{freshness.stateLabel}}</span>
            {{#if freshness.remaining}}
              <span class="wdm-food-freshness-time">· {{freshness.remaining}} day{{#unless (eq freshness.remaining "1.0")}}s{{/unless}} left</span>
            {{/if}}
          </div>
        {{/if}}
      {{/if}}

      {{#if source.description}}
        <div class="wdm-w3-description">{{{source.description}}}</div>
      {{else}}
        <div class="wdm-w3-effects wdm-empty">No description yet.</div>
      {{/if}}

      <div class="wdm-w3-footer">
        <span class="wdm-w3-foot-cell" title="Weight (kg)"><i class="fa-solid fa-weight-hanging"></i>{{source.weight}}</span>
        {{#unless (eq source.quantity 1)}}
          <span class="wdm-w3-foot-cell" title="Quantity"><i class="fa-solid fa-layer-group"></i>×{{source.quantity}}</span>
        {{/unless}}
        <span class="wdm-w3-foot-spacer"></span>
        <span class="wdm-w3-foot-cell wdm-w3-rarity" title="Rarity / Availability">{{localize (lookup WITCHER.availability source.availability)}}</span>
        <span class="wdm-w3-foot-cell wdm-w3-price" title="Crowns"><i class="fa-solid fa-coins"></i>{{source.cost}}</span>
      </div>

    </div>
  </div>

  {{!-- ════════════════════════════════════════════════════════════
       CONFIG VIEW — compact spec form
       ═══════════════════════════════════════════════════════════ --}}
  <div class="wdm-config-view">
    <div class="wdm-cfg-form">

      <div class="wdm-cfg-head">
        <img class="wdm-cfg-portrait" src="{{item.img}}" data-action="editImage" data-edit="img" alt="" title="Click to change icon" />
        <input class="wdm-cfg-name" type="text" name="name" value="{{item.name}}" placeholder="Food name" />
      </div>

      <div class="wdm-cfg-section">Details</div>
      <div class="wdm-cfg-grid">
        <label class="wdm-cfg-row" title="Display category. Drinks are the only kind that can carry alcohol metadata.">
          <span>Kind</span>
          <select name="system.kind">
            {{#each kindOptions}}
              <option value="{{@key}}" {{#if (eq @key ../kind)}}selected{{/if}}>{{this}}</option>
            {{/each}}
          </select>
        </label>
        <label class="wdm-cfg-row"><span title="Crowns per unit">Value</span>
          <input type="number" min="0" name="system.cost" value="{{source.cost}}" />
        </label>
        <label class="wdm-cfg-row"><span title="Weight per unit (kg)">Weight (kg)</span>
          <input type="number" step="0.01" min="0" name="system.weight" value="{{source.weight}}" />
        </label>
        <label class="wdm-cfg-row"><span title="How readily this is found (RAW Availability scale)">Rarity</span>
          <select name="system.availability">
            {{#each WITCHER.availability}}
              <option value="{{@key}}" {{#if (eq @key ../source.availability)}}selected{{/if}}>{{localize this}}</option>
            {{/each}}
          </select>
        </label>
      </div>

      {{> "systems/witcher-ttrpg-death-march/templates/item/partials/source-field.hbs" value=source.source}}

      {{!-- Food & Drink homebrew fields. Schema is always present (ADR 0003),
           but the UI surface hides when the toggle is off so a pure-RAW world
           doesn't see fields it can't actually use. Flipping it back on keeps
           previously-authored data intact. --}}
      {{#if foodAndDrinkOn}}
        <div class="wdm-cfg-section">Portions &amp; Satiety</div>
        <div class="wdm-cfg-grid">
          <label class="wdm-cfg-row" title="Portions left in THIS unit. When 0, consuming drops quantity by 1 and resets to max (or deletes the item).">
            <span>Current Portion</span>
            <input type="number" min="0" name="system.charges.current" value="{{source.charges.current}}" />
          </label>
          <label class="wdm-cfg-row" title="Total portions per unit (0 = no portion ticker, consume just decrements quantity).">
            <span>Max Portions</span>
            <input type="number" min="0" name="system.charges.max" value="{{source.charges.max}}" />
          </label>
          <label class="wdm-cfg-row" title="Satiety restored per portion eaten (0–125).">
            <span>Satiety Restore</span>
            <input type="number" min="0" name="system.satietyRestore" value="{{source.satietyRestore}}" />
          </label>
        </div>

        <div class="wdm-cfg-section">Freshness</div>
        <div class="wdm-cfg-grid">
          <label class="wdm-cfg-row" title="In-game days before the food spoils after it's first acquired by a character. 0 = never spoils (cured, dried, distilled).">
            <span>Shelf Life (days)</span>
            <input type="number" min="0" step="0.5" name="system.freshness.shelfLifeDays" value="{{source.freshness.shelfLifeDays}}" />
          </label>
          {{#if freshness.tracked}}
            <div class="wdm-cfg-readout" title="Days remaining before this item becomes spoiled.">
              State: <b>{{freshness.stateLabel}}</b>{{#if freshness.remaining}} · {{freshness.remaining}} day{{#unless (eq freshness.remaining "1.0")}}s{{/unless}} left{{/if}}
            </div>
          {{/if}}
        </div>

        <div class="wdm-cfg-section">Taste</div>
        <textarea class="wdm-cfg-textarea" name="system.taste"
                  placeholder="Short flavor line — printed in chat each time a portion is consumed (never on the display tooltip).">{{source.taste}}</textarea>

        {{!-- Alcohol block — only drinks can carry alcohol metadata.
             The schema accepts the values for any kind so authoring a meal
             with alcohol fields by mistake doesn't lose data; the UI just
             stops surfacing them. --}}
        {{#if isDrink}}
        <div class="wdm-cfg-section">Alcohol</div>
        <div class="wdm-cfg-grid">
          <label class="wdm-cfg-row is-checkbox" title="When ON, consuming triggers an Endurance check; failure raises the drinker's drunk level.">
            <span>Alcoholic</span>
            <input type="checkbox" name="system.drunk.isAlcohol" {{#if source.drunk.isAlcohol}}checked{{/if}} />
          </label>
          <label class="wdm-cfg-row" title="DC of the Endurance check the drinker rolls to avoid getting more drunk.">
            <span>Endurance DC</span>
            <input type="number" min="0" name="system.drunk.dc" value="{{source.drunk.dc}}" />
          </label>
          <label class="wdm-cfg-row" title="How many drunk tiers to advance on a failed save (usually 1).">
            <span>Level Jump</span>
            <input type="number" min="0" name="system.drunk.levelJump" value="{{source.drunk.levelJump}}" />
          </label>
          <label class="wdm-cfg-row" title="Verb used in chat: 'drinks', 'sips', 'guzzles', 'downs'…">
            <span>Flavor Verb</span>
            <input type="text" name="system.drunk.flavorVerb" value="{{source.drunk.flavorVerb}}" placeholder="drinks" />
          </label>
        </div>
        {{/if}}
      {{/if}}

      {{!-- Active Effects — copy onto the consumer when eaten. With duration
           the effect lingers and expires; without, it sits as a permanent
           buff/debuff (author can delete later). Effects on the food itself
           are transfer:false (handled by the sheet) so merely carrying the
           item never applies them. --}}
      {{#if foodAndDrinkOn}}
        <div class="wdm-cfg-section">Effects <span class="wdm-cfg-sub">(applied on consume)</span></div>
        <div class="wdm-cfg-effects">
          {{#if effects.length}}
            <ul class="wdm-effect-list">
              {{#each effects}}
                <li class="wdm-effect-row {{#if this.disabled}}is-disabled{{/if}}" data-effect-id="{{this.id}}">
                  <div class="wdm-effect-head">
                    <img class="wdm-effect-img" src="{{this.img}}" alt="" />
                    <span class="wdm-effect-name">{{this.name}}</span>
                    {{#if this.duration.label}}<span class="wdm-effect-duration">{{this.duration.label}}</span>{{/if}}
                    <a data-action="toggleEffect" data-effect-id="{{this.id}}" title="{{#if this.disabled}}Enable{{else}}Disable{{/if}}">
                      <i class="fa-solid {{#if this.disabled}}fa-toggle-off{{else}}fa-toggle-on{{/if}}"></i>
                    </a>
                    <a data-action="editEffect" data-effect-id="{{this.id}}" title="Edit"><i class="fa-solid fa-pen-to-square"></i></a>
                    <a data-action="deleteEffect" data-effect-id="{{this.id}}" title="Delete"><i class="fa-solid fa-trash"></i></a>
                  </div>
                </li>
              {{/each}}
            </ul>
          {{else}}
            <p class="wdm-empty">No effects configured.</p>
          {{/if}}
          <button type="button" class="wdm-add-effect" data-action="createEffect">
            <i class="fa-solid fa-plus"></i> Add Effect
          </button>
        </div>
      {{/if}}

      <div class="wdm-cfg-section">Description</div>
      <textarea class="wdm-cfg-textarea is-tall" name="system.description"
                placeholder="What it is, how it tastes, what it does…">{{source.description}}</textarea>

    </div>
  </div>

</div>
