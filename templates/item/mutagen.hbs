{{!-- Mutagen item sheet — two-layer character mutagen:
        DISPLAY  → Witcher 3 in-game tooltip aesthetic (player reads)
        CONFIG   → editable form (cog toggle, owners only)
      Colour type (red/green/blue) tints the window via `is-mut-<type>`.
      The mechanical bonus is a non-transferring ActiveEffect (granted by
      the install flow). Mutagens are NOT alchemy ingredients. --}}

<div class="wdm-item-sheet wdm-item-v2 is-mutagen is-mut-{{source.type}}" data-mode="{{mode}}">

  {{#if canEdit}}
    <button type="button" class="wdm-item-cog" data-action="toggleItemMode"
            title="{{#if (eq mode 'config')}}Back to display view{{else}}Configure item{{/if}}">
      <i class="fa-solid {{#if (eq mode 'config')}}fa-eye{{else}}fa-gear{{/if}}"></i>
    </button>
  {{/if}}

  {{!-- ════════════════════════════════════════════════════════════
       DISPLAY VIEW — Witcher 3 tooltip layout
       ═══════════════════════════════════════════════════════════ --}}
  <div class="wdm-display-view">
    <div class="wdm-w3">

      <header class="wdm-w3-head">
        <img class="wdm-w3-portrait" src="{{item.img}}" alt="" />
        <div class="wdm-w3-titles">
          <h1 class="wdm-w3-title">{{item.name}}</h1>
          <div class="wdm-w3-subtitle">{{typeLabel}} Mutagen</div>
        </div>
      </header>

      <div class="wdm-w3-hero">
        <div class="wdm-w3-hero-value">{{source.mutationDC}}</div>
        <div class="wdm-w3-hero-label">MUTATION DC</div>
      </div>

      {{#if modifiers.length}}
        <div class="wdm-w3-section-label">Effect</div>
        <ul class="wdm-w3-stats">
          {{#each modifiers}}
            <li class="wdm-w3-stat">
              <span class="val">{{this.value}}</span>
              <span class="lbl">{{this.label}}</span>
            </li>
          {{/each}}
        </ul>
      {{/if}}

      {{#if source.minorEffect}}
        <div class="wdm-w3-section-label">Minor Effect</div>
        <div class="wdm-w3-effects">{{source.minorEffect}}</div>
      {{/if}}

      {{#if source.transmutation}}
        <div class="wdm-w3-section-label">Transmutation</div>
        <div class="wdm-w3-effects">{{source.transmutation}}</div>
      {{/if}}

    </div>
  </div>

  {{!-- ════════════════════════════════════════════════════════════
       CONFIG VIEW — compact tech form.
       ═══════════════════════════════════════════════════════════ --}}
  <div class="wdm-config-view">
    <div class="wdm-cfg-form">

      <div class="wdm-cfg-head">
        <img class="wdm-cfg-portrait" src="{{item.img}}" data-action="editImage" data-edit="img" alt="" title="Click to change icon" />
        <input class="wdm-cfg-name" type="text" name="name" value="{{item.name}}" placeholder="Mutagen name" />
      </div>

      <div class="wdm-cfg-section">Mutagen</div>
      <div class="wdm-cfg-grid">
        <label class="wdm-cfg-row"><span title="Colour of the mutagen">Type</span>
          <select name="system.type">
            <option value="red"   {{#if (eq source.type "red")}}selected{{/if}}>Red</option>
            <option value="green" {{#if (eq source.type "green")}}selected{{/if}}>Green</option>
            <option value="blue"  {{#if (eq source.type "blue")}}selected{{/if}}>Blue</option>
          </select>
        </label>
        <label class="wdm-cfg-row"><span title="DC of the mutation roll to install">Mutation DC</span>
          <input type="number" min="0" name="system.mutationDC" value="{{source.mutationDC}}" />
        </label>
      </div>

      <div class="wdm-cfg-section">Minor Effect</div>
      <textarea class="wdm-cfg-textarea is-short" name="system.minorEffect" placeholder="Small blue horns">{{source.minorEffect}}</textarea>

      {{> "systems/witcher-ttrpg-death-march/templates/item/partials/source-field.hbs" value=source.source}}

      <div class="wdm-cfg-section">Transmutation</div>
      <textarea class="wdm-cfg-textarea is-short" name="system.transmutation">{{source.transmutation}}</textarea>

      <div class="wdm-cfg-section">Effect <span class="wdm-cfg-sub">(applied on install — does not auto-transfer)</span></div>
      <div class="wdm-cfg-effects">
        {{#if effects.length}}
          <ul class="wdm-effect-list">
            {{#each effects}}
              <li class="wdm-effect-row {{#if this.disabled}}is-disabled{{/if}}" data-effect-id="{{this.id}}">
                <div class="wdm-effect-head">
                  <img class="wdm-effect-img" src="{{this.img}}" alt="" />
                  <span class="wdm-effect-name">{{this.name}}</span>
                  {{#if this.duration.label}}<span class="wdm-effect-duration">{{this.duration.label}}</span>{{/if}}
                  <a data-action="toggleEffect" data-effect-id="{{this.id}}" title="{{#if this.disabled}}Enable{{else}}Disable{{/if}}">
                    <i class="fa-solid {{#if this.disabled}}fa-toggle-off{{else}}fa-toggle-on{{/if}}"></i>
                  </a>
                  <a data-action="editEffect" data-effect-id="{{this.id}}" title="Edit"><i class="fa-solid fa-pen-to-square"></i></a>
                  <a data-action="deleteEffect" data-effect-id="{{this.id}}" title="Delete"><i class="fa-solid fa-trash"></i></a>
                </div>
              </li>
            {{/each}}
          </ul>
        {{else}}
          <p class="wdm-empty">No effect configured.</p>
        {{/if}}
        <button type="button" class="wdm-add-effect" data-action="createEffect">
          <i class="fa-solid fa-plus"></i> Add Effect
        </button>
      </div>

    </div>
  </div>

</div>
