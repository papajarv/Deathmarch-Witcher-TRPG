{{!-- Note item sheet — two-layer (narrative items: clues, letters, postings):
        DISPLAY  → Witcher 3 in-game tooltip aesthetic (player reads)
        CONFIG   → editable form (cog toggle, owners only)
      Amber default accent. The text content IS the hero. A note can be
      dropped onto a scene to pin it as a notice-board parchment posting
      (see module/chrome/chrome/parchments.js). --}}

<div class="wdm-item-sheet wdm-item-v2" data-mode="{{mode}}">

  {{#if canEdit}}
    <button type="button" class="wdm-item-cog" data-action="toggleItemMode"
            title="{{#if (eq mode 'config')}}Back to display view{{else}}Configure item{{/if}}">
      <i class="fa-solid {{#if (eq mode 'config')}}fa-eye{{else}}fa-gear{{/if}}"></i>
    </button>
  {{/if}}

  {{!-- ════════════════════════════════════════════════════════════
       DISPLAY VIEW — Witcher 3 tooltip layout
       ═══════════════════════════════════════════════════════════ --}}
  <div class="wdm-display-view">
    <div class="wdm-w3">

      <header class="wdm-w3-head">
        <img class="wdm-w3-portrait" src="{{item.img}}" alt="" />
        <div class="wdm-w3-titles">
          <h1 class="wdm-w3-title">{{item.name}}</h1>
          <div class="wdm-w3-subtitle">Note</div>
        </div>
      </header>

      {{#if source.description}}
        <div class="wdm-w3-section-label">Content</div>
        <div class="wdm-w3-effects">{{{source.description}}}</div>
      {{else}}
        <div class="wdm-w3-effects wdm-empty">No content yet.</div>
      {{/if}}

      <div class="wdm-w3-pin-hint">
        <i class="fa-solid fa-thumbtack"></i> Drag onto a scene to pin it as a notice-board posting.
      </div>

    </div>
  </div>

  {{!-- ════════════════════════════════════════════════════════════
       CONFIG VIEW — compact tech form.
       ═══════════════════════════════════════════════════════════ --}}
  <div class="wdm-config-view">
    <div class="wdm-cfg-form">

      <div class="wdm-cfg-head">
        <img class="wdm-cfg-portrait" src="{{item.img}}" data-action="editImage" data-edit="img" alt="" title="Click to change icon" />
        <input class="wdm-cfg-name" type="text" name="name" value="{{item.name}}" placeholder="Note title" />
      </div>

      <div class="wdm-cfg-section">Content</div>
      <textarea class="wdm-cfg-textarea is-tall" name="system.description"
                placeholder="The text on the page, the contents of the journal, the clue itself…">{{source.description}}</textarea>

      {{> "systems/witcher-ttrpg-death-march/templates/item/partials/source-field.hbs" value=source.source}}

      <div class="wdm-cfg-section">Details</div>
      <div class="wdm-cfg-grid">
        <label class="wdm-cfg-row"><span title="Stack size">Quantity</span>
          <input type="number" min="0" name="system.quantity" value="{{source.quantity}}" />
        </label>
        <label class="wdm-cfg-row"><span title="Weight per unit (notes are non-encumbering)">Weight (kg)</span>
          <input type="number" step="0.01" min="0" name="system.weight" value="{{source.weight}}" />
        </label>
      </div>

    </div>
  </div>

</div>
