{{!-- Container item sheet — two-layer (bags, satchels, sacks):
        DISPLAY → Witcher 3 in-game tooltip aesthetic (player reads)
        CONFIG  → editable form (GM / owner with cog toggle)
      Hero is the load read — stored / capacity (kg), with a fill bar.
      Contents are added/removed via the chrome's inventory rail, not here
      (storedWeight is computed live in WitcherContainerSheet). --}}

<div class="wdm-item-sheet wdm-item-v2 is-container" data-mode="{{mode}}">

  {{!-- ── Mode toggle (top-right) ─────────────────────────────── --}}
  {{#if canEdit}}
    <button type="button" class="wdm-item-cog" data-action="toggleItemMode"
            title="{{#if (eq mode 'config')}}Back to display view{{else}}Configure item{{/if}}">
      <i class="fa-solid {{#if (eq mode 'config')}}fa-eye{{else}}fa-gear{{/if}}"></i>
    </button>
  {{/if}}

  {{!-- ════════════════════════════════════════════════════════════
       DISPLAY VIEW — Witcher 3 tooltip
       ═══════════════════════════════════════════════════════════ --}}
  <div class="wdm-display-view">
    <div class="wdm-w3">

      <header class="wdm-w3-head">
        <img class="wdm-w3-portrait" src="{{item.img}}" alt="" />
        <div class="wdm-w3-titles">
          <h1 class="wdm-w3-title">{{item.name}}</h1>
          <div class="wdm-w3-subtitle">Container</div>
        </div>
      </header>

      <div class="wdm-w3-hero">
        <div class="wdm-w3-hero-value {{#if isOver}}is-over{{/if}}">
          {{storedWeight}}{{#if hasCapacity}} / {{capacity}}{{/if}}
        </div>
        <div class="wdm-w3-hero-label">{{#if hasCapacity}}Capacity (kg){{else}}Stored (kg){{/if}}</div>
      </div>

      {{#if hasCapacity}}
        <div class="wdm-w3-capbar {{#if isOver}}is-over{{/if}}">
          <div class="wdm-w3-capbar-fill" style="width: {{fillPct}}%"></div>
        </div>
      {{/if}}

      <ul class="wdm-w3-stats">
        <li class="wdm-w3-stat">
          <span class="val">{{contentCount}}</span>
          <span class="lbl">Items Stored</span>
        </li>
      </ul>

      {{#if source.description}}
        <div class="wdm-w3-description">{{{source.description}}}</div>
      {{/if}}

      <div class="wdm-w3-footer">
        <span class="wdm-w3-foot-cell" title="Empty weight (kg)"><i class="fa-solid fa-weight-hanging"></i>{{source.weight}}</span>
        {{#if source.equipped}}
          <span class="wdm-w3-foot-cell" title="Equipped"><i class="fa-solid fa-person-walking-luggage"></i>Worn</span>
        {{/if}}
        <span class="wdm-w3-foot-spacer"></span>
        <span class="wdm-w3-foot-cell wdm-w3-price" title="Crowns"><i class="fa-solid fa-coins"></i>{{source.cost}}</span>
      </div>

    </div>
  </div>

  {{!-- ════════════════════════════════════════════════════════════
       CONFIG VIEW — compact spec form
       ═══════════════════════════════════════════════════════════ --}}
  <div class="wdm-config-view">
    <div class="wdm-cfg-form">

      <div class="wdm-cfg-head">
        <img class="wdm-cfg-portrait" src="{{item.img}}" data-action="editImage" data-edit="img" alt="" title="Click to change icon" />
        <input class="wdm-cfg-name" type="text" name="name" value="{{item.name}}" placeholder="Container name" />
      </div>

      <div class="wdm-cfg-section">Capacity</div>
      <div class="wdm-cfg-grid">
        <label class="wdm-cfg-row"><span>Capacity (kg)</span>
          <input type="number" min="0" step="0.1" name="system.carry" value="{{source.carry}}"
                 title="Maximum weight this container can hold. 0 = unlimited." />
        </label>
        <label class="wdm-cfg-row"><span>Equipped</span>
          <input type="checkbox" name="system.equipped" {{#if source.equipped}}checked{{/if}}
                 title="Worn / carried on the body." />
        </label>
      </div>

      <div class="wdm-cfg-section">Procurement</div>
      <div class="wdm-cfg-grid">
        <label class="wdm-cfg-row"><span>Empty Weight (kg)</span>
          <input type="number" step="0.01" min="0" name="system.weight" value="{{source.weight}}" />
        </label>
        <label class="wdm-cfg-row"><span>Cost</span>
          <input type="number" min="0" name="system.cost" value="{{source.cost}}" />
        </label>
        <label class="wdm-cfg-row"><span>Quantity</span>
          <input type="number" min="0" name="system.quantity" value="{{source.quantity}}" />
        </label>
      </div>

      {{> "systems/witcher-ttrpg-death-march/templates/item/partials/source-field.hbs" value=source.source}}

      <div class="wdm-cfg-section">Description</div>
      <textarea class="wdm-cfg-textarea" name="system.description" placeholder="What it looks like, where it's worn…">{{source.description}}</textarea>

    </div>
  </div>

</div>
